-- ===== 処理 =====

local MIN = 70
local MAX = 120
local dragging = false
local selectedFov = 95
local thirdPerson = false
local loopKillEnabled = false

local function updateSlider(x)
	local percent = math.clamp(
		(x - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X,
		0,
		1
	)

	fill.Size = UDim2.new(percent,0,1,0)
	knob.Position = UDim2.new(percent,-9,0.5,-9)

	selectedFov = math.floor(MIN + ((MAX - MIN) * percent))
	valueLabel.Text = selectedFov .. " Deg"
end

-- スライド開始
sliderBg.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		
		dragging = true
		frame.Draggable = false
		
		updateSlider(input.Position.X)
	end
end)

-- スライド中
UIS.InputChanged:Connect(function(input)
	if dragging then
		if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then
			
			updateSlider(input.Position.X)
		end
	end
end)

-- 離した
UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		
		dragging = false
		frame.Draggable = true
	end
end)

-- Apply
apply.MouseButton1Click:Connect(function()
	camera.FieldOfView = selectedFov
end)

-- 三人称
thirdButton.MouseButton1Click:Connect(function()
	thirdPerson = not thirdPerson
	
	if thirdPerson then
		thirdButton.Text = "ON"
		thirdButton.BackgroundColor3 = Color3.fromRGB(0,120,255)

		player.CameraMode = Enum.CameraMode.Classic
		player.CameraMaxZoomDistance = 5000
		player.CameraMinZoomDistance = 0
	else
		thirdButton.Text = "OFF"
		thirdButton.BackgroundColor3 = Color3.fromRGB(40,40,40)

		player.CameraMode = Enum.CameraMode.LockFirstPerson
	end
end)

-- 一回キル
killOnce.MouseButton1Click:Connect(function()
	local character = player.Character
	
	if character and character:FindFirstChild("Humanoid") then
		character.Humanoid.Health = 0
	end
end)

-- ループキル
loopKill.MouseButton1Click:Connect(function()
	loopKillEnabled = not loopKillEnabled
	
	if loopKillEnabled then
		loopKill.Text = "Loop Kill ON"
		loopKill.BackgroundColor3 = Color3.fromRGB(170,40,40)
	else
		loopKill.Text = "Loop Kill OFF"
		loopKill.BackgroundColor3 = Color3.fromRGB(40,40,40)
	end
end)

-- ループ処理
task.spawn(function()
	while task.wait(1) do
		if loopKillEnabled then
			local character = player.Character
			
			if character and character:FindFirstChild("Humanoid") then
				character.Humanoid.Health = 0
			end
		end
	end
end)

-- 閉じる
close.MouseButton1Click:Connect(function()
	frame.Visible = false
	open.Visible = true
end)

-- 開く
open.MouseButton1Click:Connect(function()
	frame.Visible = true
	open.Visible = false
end)

